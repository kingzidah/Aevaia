// ── Prisma 7 notes ───────────────────────────────────────────────────────────
//  • generator provider stays "prisma-client" (renamed from "prisma-client-js" in v7)
//  • url is NOT in the datasource block — Prisma 7 requires it in prisma.config.ts
//    (adding it here causes P1012: "The datasource property `url` is no longer supported in schema files")
//  • output path preserved so lib/prisma.ts keeps its import from ./generated/prisma/client
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Tier {
  FREE
  INTIMATE
  EVENT
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELED
}

enum Theme {
  dark
  light
  custom
}

enum AssetType {
  vector
  text
  audio
  voice
  video
}

// ── Models ───────────────────────────────────────────────────────────────────

// The User model is retained for Subscription and UsageTracking relations.
// Authentication is handled by Clerk — userId fields throughout the schema
// store Clerk user IDs (format: user_xxxxxxxxxxxxxxxxxxxx) directly, with
// no FK constraint to this table so no local User record is required on login.
model User {
  id           String   @id @default(uuid())
  clerkId      String?  @unique // Clerk user ID — set on first subscription/usage write
  email        String   @unique
  name         String?
  credits      Int      @default(1000) // HeartCraft AI generation credits
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id          String  @id @default(uuid())
  // Clerk user ID — plain string, no FK so any Clerk userId works immediately
  userId      String
  title       String  @default("Untitled Masterpiece")
  scenesJson  String  @db.Text // Serialized canvas state
  isPublished String  @default("DRAFT") // DRAFT | PUBLISHED
  isPaid      Boolean @default(false)
  tier        Tier    @default(FREE)

  // Bouncer security fields
  guestList    String[] @default([])
  claimedNames String[] @default([])
  deviceCount  Int      @default(0)
  deviceCap    Int      @default(5)

  // AI orchestration context fields
  theme         Theme?            // nullable: safe before migration adds column
  brandColors   String[] @default([])
  fontFamily    String   @default("Inter")
  fontWeights   Int[]    @default([400, 700])
  fontSizeBase  String   @default("16px")
  narrativeTone String   @default("elegant and heartfelt")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  aiGenerations   AiGeneration[]
  workspaceAssets WorkspaceAsset[]

  @@index([userId]) // fast lookup of all projects for a given Clerk user
}

model AiGeneration {
  id        String   @id @default(uuid())
  projectId String
  prompt    String   @db.Text
  response  String   @db.Text
  modelUsed String   @default("google/gemini-2.5-flash")
  tokensUsed Int     @default(0)
  createdAt DateTime @default(now())

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId]) // required for fast project-scoped generation history queries
}

model Subscription {
  id               String             @id @default(uuid())
  userId           String             @unique // Clerk user ID
  stripeCustomerId String             @unique
  stripePriceId    String?
  status           SubscriptionStatus @default(INACTIVE)
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model UsageTracking {
  id           String   @id @default(uuid())
  userId       String   // Clerk user ID
  aiCredits    Int      @default(10)
  requestCount Int      @default(0)
  date         DateTime @default(now())

  @@index([userId])
}

model SupportTicket {
  id        String   @id @default(uuid())
  email     String
  message   String   @db.Text
  createdAt DateTime @default(now())
}

// Idempotency ledger for Stripe webhooks. The Stripe event id is the primary
// key, so recording it inside the fulfilment transaction makes a duplicate
// delivery (Stripe guarantees at-least-once) fail the unique constraint and
// roll the whole transaction back — a webhook retry can never double-credit.
model ProcessedStripeEvent {
  id          String   @id // Stripe event id, e.g. evt_1AbCd...
  type        String
  processedAt DateTime @default(now())
}

model WorkspaceAsset {
  id        String    @id @default(uuid())
  projectId String
  type      AssetType
  content   String    @db.Text
  metadata  Json?
  createdAt DateTime  @default(now())

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
